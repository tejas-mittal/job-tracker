# Oracle Cloud Public IP or Free Domain (e.g. my-job-tracker.duckdns.org)
DOMAIN=localhost

# Secure JWT Secret for Production (Make sure this is long and random!)
JWT_SECRET=super-secure-production-jwt-secret-minimum-32-chars-long!

# Google OAuth2 Credentials (for the Email Sync feature)
# You get these from console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
